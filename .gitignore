# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# cloudflare
.open-next/
.wrangler/

# local dev seed (contains credentials)
db/seed.sql

# IDE
.idea/
.vscode/
*.swp
*.swo

# Temp
tmp/
temp/

# Secrets
*.gao

# Claude Code — selectively track agents and skills
/.claude/*
!/.claude/agents/
!/.claude/rules/
!/.claude/skills/

# Dark Factory worktrees and results
.claude/worktrees/
dark-factory/results/

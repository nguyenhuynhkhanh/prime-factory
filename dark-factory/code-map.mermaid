graph TD
    subgraph Skills["Skills (Entry Points)"]
        df["df/SKILL.md<br/>(router)"]
        intake["df-intake/SKILL.md"]
        debug["df-debug/SKILL.md"]
        orchestrate["df-orchestrate/SKILL.md<br/>--group / --all / --skip-tests / --mode / --afk"]
        onboard["df-onboard/SKILL.md"]
        cleanup["df-cleanup/SKILL.md<br/>(--rebuild-index / --rebuild-memory)"]
    end

    subgraph Agents["Agents (10)"]
        spec["spec-agent<br/>(reads intent-foundation.md)"]
        dbg["debug-agent"]
        architect["architect-agent<br/>(3 parallel domains;<br/>Gate 1/2/3)"]
        code["code-agent<br/>(1-4 in worktrees;<br/>BLOCKED result)"]
        test["test-agent<br/>(validator + advisor modes;<br/>Step 2.75 regression gate)"]
        promote["promote-agent<br/>(shard-first memory write;<br/>DI write-through)"]
        impl["implementation-agent<br/>(4-gate lifecycle;<br/>Step 2.75 regression flags)"]
        codemap["codemap-agent"]
        onboardA["onboard-agent<br/>(Phase 3.7d DI)"]
        qa["qa-agent<br/>(QA_SCENARIO;<br/>coverage-map.json)"]
    end

    subgraph Memory["Intent & Memory (Hotspots)"]
        foundation["intent-foundation.md<br/>Layer 0; fan-in: 3"]:::hotspot
        adr["intent-adr-{spec_id}.md<br/>Layer 2 ADRs; fan-in: 4"]:::hotspot
        coverage["results/{name}/coverage-map.json<br/>(Gate 2 artifact)"]
    end

    subgraph SharedData["Shared Data (Hotspots)"]
        profile["project-profile.md<br/>fan-in: 10"]:::hotspot
        map["code-map.md<br/>fan-in: 9"]:::hotspot
        manifest["manifest.json<br/>fan-in: 6"]:::hotspot
        memIdx["memory/index.md<br/>fan-in: 5"]:::hotspot
        diShards["memory/design-intent-{domain}.md<br/>fan-in: 5"]:::hotspot
        promoted["promoted-tests.json<br/>fan-in: 4; 16 entries"]:::hotspot
        tmpl["project-profile-template.md"]
        memShards["memory/ INV/DEC shards<br/>+ ledger.md"]
    end

    subgraph CLI["CLI"]
        cli["bin/cli.js"]
        plugin["plugins/dark-factory/<br/>(10 agents mirrored)"]
    end

    subgraph Tests["Tests"]
        setup["dark-factory-setup.test.js<br/>(16 promoted sections)"]
        contracts["dark-factory-contracts.test.js<br/>(lifecycle mirror parity)"]
    end

    %% Skill routing
    df --> intake
    df --> debug

    %% Skill -> Agent spawning
    intake --> codemap
    intake --> spec
    intake -->|"Step 5 QA_SCENARIO"| qa
    intake -->|"Step 5.5 advisor mode"| test
    debug --> codemap
    debug --> dbg
    orchestrate --> codemap
    orchestrate --> impl
    onboard --> onboardA
    cleanup --> promote
    cleanup --> promoted
    cleanup -.->|"--rebuild-index / --rebuild-memory"| memIdx

    %% Agent -> Agent spawning (3-gate pipeline)
    impl -->|"Gate 1 ARCH_SPEC_REVIEW"| architect
    impl -->|"QA_SCENARIO after Gate 1"| qa
    impl --> code
    impl -->|"Gate 4 validator mode"| test
    impl --> promote
    impl -->|"flaky-E2E (bugfix)"| spec
    impl -->|"blockers"| spec
    impl -->|"blockers"| dbg
    architect -->|"spec revision"| spec
    architect -->|"debug revision"| dbg
    onboardA --> codemap

    %% Gate artifact chain
    architect -->|"writes Gate 1"| adr
    qa -->|"reads ADRs"| adr
    qa -->|"writes"| coverage
    architect -->|"reads Gate 2"| coverage
    spec -->|"reads Layer 0"| foundation
    qa -->|"reads Layer 0"| foundation
    architect -->|"reads Layer 0"| foundation

    %% Step 2.75 regression gate
    test -->|"reads Step 2.75"| promoted
    test -.->|"advisor: reads"| memIdx

    %% Agent -> Shared Data reads
    spec --> profile
    spec --> map
    dbg --> profile
    dbg --> map
    architect --> profile
    architect --> map
    code --> profile
    code --> map
    test --> profile
    test --> map
    promote --> profile
    promote --> map
    promote --> promoted
    promote -.->|"writes shard-first"| memShards
    impl --> manifest
    intake --> manifest
    debug --> manifest
    orchestrate --> manifest
    cleanup --> manifest
    onboardA -.-> profile
    onboardA --> tmpl
    onboardA -.-> memShards
    codemap -.-> map
    spec --> memIdx
    dbg --> memIdx
    code --> memIdx
    architect --> diShards
    spec --> diShards
    onboardA -.-> diShards

    %% CLI
    cli --> plugin

    %% Tests read everything
    setup --> spec
    setup --> dbg
    setup --> architect
    setup --> code
    setup --> test
    setup --> promote
    setup --> impl
    setup --> codemap
    setup --> onboardA
    setup --> qa
    setup --> tmpl
    setup --> promoted
    contracts --> plugin
    contracts --> qa
    contracts --> test
    contracts --> promote
    contracts --> impl

    %% Styles
    classDef hotspot fill:#ff6b6b,stroke:#c92a2a,color:#fff,stroke-width:2px
    classDef agent fill:#4dabf7,stroke:#1971c2,color:#fff
    classDef skill fill:#69db7c,stroke:#2b8a3e,color:#fff
    classDef test fill:#ffd43b,stroke:#e67700,color:#000
    classDef intent fill:#e599f7,stroke:#7048e8,color:#000,stroke-width:2px

    class spec,dbg,architect,code,test,promote,impl,codemap,onboardA,qa agent
    class df,intake,debug,orchestrate,onboard,cleanup skill
    class setup,contracts test
    class foundation,adr intent

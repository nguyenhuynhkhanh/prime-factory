# Copy this file to .env.local and fill in your values.

# Required for local dev — generate with: openssl rand -hex 32
API_KEY_SALT=change-me-in-production

# Required for drizzle-kit (remote D1 migrations only — not needed for local dev)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=

# URL shown in invite links (e.g. http://localhost:3000 for local dev)
APP_URL=http://localhost:3000
